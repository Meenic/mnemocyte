{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"rootDir": ".",
		"noEmit": true,
		"types": ["node", "vitest"],
		"ignoreDeprecations": "6.0",
		"baseUrl": ".",
		"paths": {
			"mnemocyte": ["./src/index.ts"],
			"mnemocyte/embedders": ["./src/embedders/index.ts"],
			"mnemocyte/embedders/*": ["./src/embedders/*.ts"]
		}
	},
	"include": ["src", "test/**/*.ts", "vitest.config.ts"],
	"exclude": ["node_modules", "dist", "test/package/exports-types.test-d.ts"]
}
