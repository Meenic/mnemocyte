{
	"name": "mnemocyte",
	"version": "0.0.1",
	"description": "Persistent memory for TypeScript AI apps.",
	"type": "module",
	"sideEffects": false,
	"files": [
		"dist"
	],
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.js"
			}
		}
	},
	"types": "./dist/index.d.ts",
	"main": "./dist/index.js",
	"scripts": {
		"build": "tsdown src/index.ts",
		"dev": "tsdown src/index.ts --watch",
		"checktypes": "tsc --noEmit",
		"lint": "biome lint --write",
		"format": "biome format --write",
		"prepublishOnly": "pnpm build && pnpm checktypes"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/Meenic/mnemocyte.git"
	},
	"keywords": [
		"ai",
		"memory",
		"llm",
		"agents",
		"typescript",
		"postgres",
		"pgvector"
	],
	"author": "Meenic",
	"license": "MIT",
	"funding": "https://github.com/sponsors/Meenic",
	"bugs": {
		"url": "https://github.com/Meenic/mnemocyte/issues"
	},
	"homepage": "https://github.com/Meenic/mnemocyte#readme",
	"publishConfig": {
		"access": "public",
		"provenance": true
	},
	"engines": {
		"node": ">=22.18.0"
	},
	"devEngines": {
		"packageManager": {
			"name": "pnpm",
			"version": "^11.0.8",
			"onFail": "download"
		}
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.15",
		"@types/node": "^25.7.0",
		"tsdown": "^0.22.0",
		"typescript": "^6.0.3"
	}
}
