{
	"name": "mnemocyte",
	"version": "0.1.2",
	"description": "Persistent memory for TypeScript AI apps.",
	"type": "module",
	"packageManager": "pnpm@11.1.1",
	"sideEffects": false,
	"files": [
		"dist",
		"migrations"
	],
	"exports": {
		".": {
			"types": "./dist/index.d.mts",
			"import": "./dist/index.mjs"
		}
	},
	"types": "./dist/index.d.mts",
	"scripts": {
		"build": "tsdown src/index.ts",
		"dev": "tsdown src/index.ts --watch",
		"checktypes": "tsc --noEmit && tsc --noEmit --project tsconfig.test.json",
		"test": "pnpm run test:ci",
		"test:ci": "pnpm build && vitest run --typecheck --project unit --project package",
		"test:unit": "vitest run --project unit",
		"test:exports": "pnpm build && vitest run --typecheck --project package",
		"test:observability": "vitest run --project unit test/observability/hooks.test.ts",
		"test:resilience": "vitest run --project unit test/resilience/resilience.test.ts",
		"test:prune": "vitest run --project unit test/prune/prune.test.ts",
		"test:lifecycle": "vitest run --project unit test/lifecycle/close.test.ts",
		"test:dedup": "vitest run --project unit test/dedup/find-duplicates.test.ts",
		"test:audit": "vitest run --project unit test/audit/audit-log.test.ts",
		"test:consolidate": "vitest run --project unit test/consolidate/consolidate.test.ts",
		"test:retrieval": "vitest run --project unit test/retrieval/quality.test.ts",
		"test:context": "vitest run --project unit test/context/builder.test.ts",
		"test:integration": "vitest run --project integration",
		"bench:retrieval": "vitest bench --project unit test/benchmarks/retrieval.bench.ts",
		"lint": "biome lint --write",
		"format": "biome format --write",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"pack:check": "pnpm pack --dry-run",
		"prepublishOnly": "tsdown src/index.ts && tsc --noEmit && pnpm pack --dry-run"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/Meenic/mnemocyte.git"
	},
	"keywords": [
		"ai",
		"memory",
		"llm",
		"agents",
		"typescript",
		"postgres",
		"pgvector"
	],
	"author": "Meenic",
	"license": "MIT",
	"funding": "https://github.com/sponsors/Meenic",
	"bugs": {
		"url": "https://github.com/Meenic/mnemocyte/issues"
	},
	"homepage": "https://github.com/Meenic/mnemocyte#readme",
	"publishConfig": {
		"access": "public",
		"provenance": true
	},
	"engines": {
		"node": ">=22.18"
	},
	"dependencies": {
		"drizzle-orm": "^0.45.2",
		"postgres": "^3.4.9"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.15",
		"@types/node": "^25.9.0",
		"drizzle-kit": "^0.31.10",
		"tsdown": "^0.22.0",
		"typescript": "^6.0.3",
		"vitest": "4.1.6"
	}
}
