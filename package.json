{
	"name": "mnemocyte",
	"version": "0.0.8",
	"description": "Persistent memory for TypeScript AI apps.",
	"type": "module",
	"packageManager": "pnpm@11.1.1",
	"sideEffects": false,
	"files": [
		"dist",
		"migrations"
	],
	"exports": {
		".": {
			"types": "./dist/index.d.mts",
			"import": "./dist/index.mjs"
		}
	},
	"types": "./dist/index.d.mts",
	"scripts": {
		"build": "tsdown src/index.ts",
		"dev": "tsdown src/index.ts --watch",
		"checktypes": "tsc --noEmit",
		"test:exports": "tsdown src/index.ts && node test/package/exports.test.mjs && tsc -p test/package/tsconfig.json",
		"test:observability": "tsdown src/index.ts && node test/observability/hooks.test.mjs",
		"test:resilience": "tsdown src/index.ts && node test/resilience/resilience.test.mjs",
		"test:prune": "tsdown src/index.ts && node test/prune/prune.test.mjs",
		"test:retrieval": "tsdown src/index.ts && node test/retrieval/quality.test.mjs",
		"test:context": "tsdown src/index.ts && node test/context/builder.test.mjs",
		"test:integration": "tsdown src/index.ts && node test/integration/postgres.test.mjs",
		"bench:retrieval": "tsdown src/index.ts && node test/benchmarks/retrieval.bench.mjs",
		"lint": "biome lint --write",
		"format": "biome format --write",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"pack:check": "pnpm pack --pack-destination .pack-check",
		"prepublishOnly": "tsdown src/index.ts && tsc --noEmit && pnpm pack --pack-destination .pack-check"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/Meenic/mnemocyte.git"
	},
	"keywords": [
		"ai",
		"memory",
		"llm",
		"agents",
		"typescript",
		"postgres",
		"pgvector"
	],
	"author": "Meenic",
	"license": "MIT",
	"funding": "https://github.com/sponsors/Meenic",
	"bugs": {
		"url": "https://github.com/Meenic/mnemocyte/issues"
	},
	"homepage": "https://github.com/Meenic/mnemocyte#readme",
	"publishConfig": {
		"access": "public",
		"provenance": true
	},
	"engines": {
		"node": ">=22.18"
	},
	"dependencies": {
		"drizzle-orm": "^0.45.2",
		"postgres": "^3.4.7"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.15",
		"@types/node": "^25.7.0",
		"drizzle-kit": "^0.31.0",
		"tsdown": "^0.22.0",
		"typescript": "^6.0.3"
	}
}
